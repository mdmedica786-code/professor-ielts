# === API Keys ===
# REQUIRED. The live pipeline (transcription, disfluency analysis, FC/LR/GRA
# grading, question generation) runs entirely on OpenAI. The app will not work
# without this key.
OPENAI_API_KEY=sk-your_openai_api_key_here

# OPTIONAL / LEGACY. groqService.js and geminiService.js are alternate provider
# implementations that are NOT wired into the routes. Leave blank unless you
# switch the services back to them.
# GROQ_API_KEY=gsk_your_groq_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# === Server Config ===
NODE_PORT=3001
PYTHON_PRONUNCIATION_URL=http://localhost:8000
CORS_ORIGIN=http://localhost:5173

# Comma-separated list of allowed origins for rate-limit bypass is not needed;
# RATE_LIMIT_* below tune the abuse protection (optional — sensible defaults).
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=60

# === Model Config (only used by the optional Python pronunciation service) ===
WAV2VEC2_MODEL=facebook/wav2vec2-lv-60-espeak-cv-ft
MFA_ACOUSTIC_MODEL=english_mfa
MFA_DICTIONARY=english_mfa
